# Rename this file to config.env before running the Go service.

####################
## REQUIRED SETTINGS
####################

# Telegram bot token from @BotFather
BOT_TOKEN=""

# Telegram API credentials used for MTProto direct streaming.
API_ID=0
API_HASH=""

# Storage channel ID where the bot forwards incoming files.
# The bot must be an admin there.
BIN_CHANNEL=0

# Owner IDs allowed to use /status.
# Supports one value in OWNER_ID or multiple values in OWNER_IDS.
OWNER_ID=0
# OWNER_IDS="123456789,987654321"

# Public base URL used to generate links.
# Prefer PUBLIC_BASE_URL if you already know the full URL.
PUBLIC_BASE_URL=""

# Or build the URL from these values.
FQDN=""
HAS_SSL="true"
NO_PORT="true"

# HTTP listen address for the Go service.
BIND_ADDRESS="0.0.0.0"
PORT=8080

####################
## SQLITE SETTINGS
####################

# Preferred option.
SQLITE_PATH="data/tg-file-url.db"
LOG_PATH="data/tg-file-url.log"

# MTProto session file persisted by the Go service.
MTPROTO_SESSION_PATH="data/mtproto-bot.session"

# Backward-compatible alternative if you want to reuse DATABASE_URL.
# Examples:
# DATABASE_URL="data/tg-file-url.db"
# DATABASE_URL="sqlite:///data/tg-file-url.db"
# DATABASE_URL="file:data/tg-file-url.db"
DATABASE_URL=""

####################
## OPTIONAL SETTINGS
####################

# Telegram Bot API base URL.
# Default is the public cloud API. If you run a local Bot API server,
# point this at that server for better large-file support.
TELEGRAM_API_BASE_URL="https://api.telegram.org"

# Long-poll timeout for update fetching.
POLL_TIMEOUT_SECONDS=30

# HTTP client timeout for Telegram API calls and file proxy requests.
HTTP_TIMEOUT_SECONDS=60

